# File da copiare a .env in produzione.
# In dev locale non serve: il backend usa il cluster Postgres dev :5434
# (vedi backend/core/settings/base.py).

# --- Postgres ---
POSTGRES_DB=viapal
POSTGRES_USER=viapal
POSTGRES_PASSWORD=changeme

# --- Django ---
DJANGO_SECRET_KEY=changeme-genera-una-chiave-lunga
DJANGO_ALLOWED_HOSTS=viapal.e-den.it

# --- Immagini Docker (riempite dal CI/CD) ---
BACKEND_IMAGE=ghcr.io/sandroden/viapal-backend:latest
FRONTEND_IMAGE=ghcr.io/sandroden/viapal-frontend:latest
