# File da copiare a .env in produzione, accanto al docker-compose.yml.
# In dev locale non serve: il backend usa il cluster Postgres dev :5434
# (vedi backend/core/settings/base.py).
#
# Settings Django sensibili (SECRET_KEY, DATABASES, ALLOWED_HOSTS) vanno
# nel local.py montato come volume — vedi local.py.example.

# --- Traefik (host pubblico, usato dalle label nel docker-compose.yml) ---
HOST=viapal.e-den.it

# --- Immagini Docker (riempite dal CI/CD) ---
BACKEND_IMAGE=ghcr.io/sandroden/viapal-backend:latest
FRONTEND_IMAGE=ghcr.io/sandroden/viapal-frontend:latest
