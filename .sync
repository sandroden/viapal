# -*- mode: sh -*-

# La password deve essere memorizzata in .pgpass sul server remoto
# es.::
# echo localhost:5432:dbname:dbuser:pass  >> /root/.pgpass
# chmod 600 /root/.pgpass
## Postgresql
APP_HOST=root@mio3.e-den.it
DB_HOST=localhost   # as seen from APP_HOST
DB_NAME=viapal
DB_USER=viapal

## Sqlite
#DB_PATH=/path/to/remote/db

## Local admin/thunder
RESET_USER=admin            # normalmente admin o thunder, la password verrà chiesta interattivamente

# PORTE
REMOTE_PORT=5433
LOCAL_PORT=5434
